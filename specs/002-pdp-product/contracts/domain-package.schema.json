{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pdp.example.com/schemas/domain-package/v1.json",
  "title": "PDP 领域包清单",
  "description": "用于平台标准包、行业领域包和工作空间客户包的声明式配置交换与发布校验。覆盖 FR-007~FR-020、FR-130~FR-134、FR-167、FR-168、FR-172：三层继承、核心字段复用、状态机、规则、权限、受治理扩展、版本快照、影响预览、迁移与回滚。",
  "type": "object",
  "required": [
    "schemaVersion",
    "stableKey",
    "name",
    "layer",
    "version",
    "objects",
    "designer",
    "publisher"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "stableKey": {
      "$ref": "#/$defs/stableKey"
    },
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "layer": {
      "enum": [
        "PLATFORM_STANDARD",
        "INDUSTRY",
        "WORKSPACE_CUSTOMER"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "extends": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageKey",
        "versionRange"
      ],
      "properties": {
        "packageKey": {
          "$ref": "#/$defs/stableKey"
        },
        "versionRange": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "parentSnapshotId": {
          "description": "继承自父包的运行时快照标识；发布前必须与父包已发布版本一致。",
          "oneOf": [
            {
              "$ref": "#/$defs/stableKey"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "designer": {
      "description": "设计者（提交候选版本），与 publisher 必须不同（FR-167、US2 验收场景 3）。",
      "$ref": "#/$defs/principalRef"
    },
    "publisher": {
      "description": "独立发布者（完成测试与影响审核后发布），与 designer 必须不同。",
      "$ref": "#/$defs/principalRef"
    },
    "coreFieldReuse": {
      "type": "array",
      "description": "声明本包扩展字段与平台核心字段目录的复用或差异关系；FR-132、FR-134。",
      "items": {
        "$ref": "#/$defs/coreFieldReuseDeclaration"
      },
      "default": []
    },
    "objects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/objectDefinition"
      }
    },
    "pages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pageDefinition"
      },
      "default": []
    },
    "views": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/viewDefinition"
      },
      "default": []
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ruleDefinition"
      },
      "default": []
    },
    "workflowBindings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflowBindingDefinition"
      },
      "default": []
    },
    "permissions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/permissionDefinition"
      },
      "default": []
    },
    "extensions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/extensionDefinition"
      },
      "default": []
    },
    "overrides": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/overrideDefinition"
      },
      "default": []
    },
    "migrations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/migrationDefinition"
      },
      "default": []
    },
    "runtimeSnapshot": {
      "description": "发布时生成的运行时版本快照；运行实例默认绑定此快照，FR-018。",
      "oneOf": [
        {
          "$ref": "#/$defs/runtimeSnapshot"
        },
        {
          "type": "null"
        }
      ]
    },
    "compatibilityStatement": {
      "description": "本版本相对父包的兼容性声明；用于 FR-172 兼容影响记录。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compatibilityLevel",
        "consumerImpact"
      ],
      "properties": {
        "compatibilityLevel": {
          "enum": [
            "MAJOR_BREAKING",
            "MINOR_BREAKING",
            "ADDITIVE",
            "PATCH_ONLY"
          ]
        },
        "consumerImpact": {
          "type": "string",
          "maxLength": 2000
        },
        "deprecationWindow": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "deprecatedAt": {
              "type": "string",
              "format": "date-time"
            },
            "sunsetAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "stableKey": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9.-]{2,99}$"
    },
    "principalRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "principalType",
        "principalId"
      ],
      "properties": {
        "principalType": {
          "enum": [
            "USER",
            "SERVICE_ACCOUNT",
            "GOVERNANCE_ROLE"
          ]
        },
        "principalId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "displayLabel": {
          "type": "string",
          "maxLength": 200
        }
      }
    },
    "coreFieldReuseDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coreFieldKey",
        "disposition"
      ],
      "properties": {
        "coreFieldKey": {
          "$ref": "#/$defs/stableKey",
          "description": "平台核心字段目录中的稳定键。"
        },
        "disposition": {
          "enum": [
            "REUSE",
            "DIFFERENTIATE",
            "AUGMENT"
          ],
          "description": "REUSE 直接复用核心字段；DIFFERENTIATE 创建语义差异字段并必须声明理由；AUGMENT 在核心字段基础上增加受控扩展。"
        },
        "reason": {
          "type": "string",
          "minLength": 0,
          "maxLength": 1000
        },
        "extensionFieldKey": {
          "$ref": "#/$defs/stableKey"
        }
      }
    },
    "localizedText": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "maxLength": 500
      }
    },
    "objectDefinition": {
      "type": "object",
      "required": [
        "stableKey",
        "kind",
        "label",
        "fields",
        "states"
      ],
      "additionalProperties": false,
      "properties": {
        "stableKey": {
          "$ref": "#/$defs/stableKey"
        },
        "kind": {
          "enum": [
            "CORE_EXTENSION",
            "NEW_OBJECT"
          ]
        },
        "coreObjectType": {
          "$ref": "#/$defs/stableKey"
        },
        "label": {
          "$ref": "#/$defs/localizedText"
        },
        "titleFieldKey": {
          "$ref": "#/$defs/stableKey"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fieldDefinition"
          }
        },
        "relations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relationDefinition"
          },
          "default": []
        },
        "states": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/stateDefinition"
          }
        },
        "transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transitionDefinition"
          },
          "default": []
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "CORE_EXTENSION"
              }
            }
          },
          "then": {
            "required": [
              "coreObjectType"
            ]
          }
        }
      ]
    },
    "fieldDefinition": {
      "type": "object",
      "required": [
        "stableKey",
        "label",
        "dataType"
      ],
      "additionalProperties": false,
      "properties": {
        "stableKey": {
          "$ref": "#/$defs/stableKey"
        },
        "label": {
          "$ref": "#/$defs/localizedText"
        },
        "dataType": {
          "enum": [
            "TEXT",
            "LONG_TEXT",
            "INTEGER",
            "DECIMAL",
            "BOOLEAN",
            "DATE",
            "DATETIME",
            "ENUM",
            "USER_REF",
            "ORG_REF",
            "OBJECT_REF",
            "FILE_REF",
            "GEO_POINT",
            "JSON"
          ]
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "sensitive": {
          "type": "boolean",
          "default": false
        },
        "uniqueScope": {
          "enum": [
            "NONE",
            "WORKSPACE",
            "PROJECT",
            "OBJECT_TYPE"
          ],
          "default": "NONE"
        },
        "indexMode": {
          "enum": [
            "NONE",
            "FILTER",
            "SORT",
            "SEARCH",
            "AGGREGATE"
          ],
          "default": "NONE"
        },
        "coreFieldKey": {
          "description": "若该字段直接复用平台核心字段目录中的字段，填写对应 stableKey；FR-132、FR-134 发布前检测重名/语义/标识/数据来源冲突。",
          "oneOf": [
            {
              "$ref": "#/$defs/stableKey"
            },
            {
              "type": "null"
            }
          ]
        },
        "defaultValue": {},
        "validation": {
          "type": "object",
          "additionalProperties": true
        },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "key",
              "label"
            ],
            "properties": {
              "key": {
                "$ref": "#/$defs/stableKey"
              },
              "label": {
                "$ref": "#/$defs/localizedText"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "relationDefinition": {
      "type": "object",
      "required": [
        "stableKey",
        "targetObjectKey",
        "cardinality"
      ],
      "additionalProperties": false,
      "properties": {
        "stableKey": {
          "$ref": "#/$defs/stableKey"
        },
        "targetObjectKey": {
          "$ref": "#/$defs/stableKey"
        },
        "cardinality": {
          "enum": [
            "ONE_TO_ONE",
            "ONE_TO_MANY",
            "MANY_TO_ONE",
            "MANY_TO_MANY"
          ]
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "ownership": {
          "enum": [
            "REFERENCE",
            "AGGREGATE_CHILD"
          ],
          "default": "REFERENCE"
        }
      }
    },
    "stateDefinition": {
      "type": "object",
      "required": [
        "stableKey",
        "label",
        "topLifecycleState"
      ],
      "additionalProperties": false,
      "properties": {
        "stableKey": {
          "$ref": "#/$defs/stableKey"
        },
        "label": {
          "$ref": "#/$defs/localizedText"
        },
        "topLifecycleState": {
          "enum": [
            "PRE_PLANNING",
            "PLANNING",
            "EXECUTING",
            "ACCEPTING",
            "SERVICING",
            "CLOSED",
            "CANCELLED"
          ]
        },
        "initial": {
          "type": "boolean",
          "default": false
        },
        "terminal": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "transitionDefinition": {
      "type": "object",
      "required": [
        "stableKey",
        "from",
        "to",
        "requiredPermission"
      ],
      "additionalProperties": false,
      "properties": {
        "stableKey": {
          "$ref": "#/$defs/stableKey"
        },
        "from": {
          "$ref": "#/$defs/stableKey"
        },
        "to": {
          "$ref": "#/$defs/stableKey"
        },
        "requiredPermission": {
          "$ref": "#/$defs/stableKey"
        },
        "guardRuleKey": {
          "$ref": "#/$defs/stableKey"
        },
        "approvalDefinitionKey": {
          "$ref": "#/$defs/stableKey"
        },
        "workflowBindingKey": {
          "$ref": "#/$defs/stableKey"
        },
        "reversible": {
          "type": "boolean",
          "default": true
        },
        "auditLevel": {
          "enum": [
            "STANDARD",
            "HIGH_RISK"
          ],
          "default": "STANDARD"
        }
      }
    },
    "workflowBindingDefinition": {
      "type": "object",
      "required": [
        "stableKey",
        "processDefinitionKey",
        "businessVersion",
        "bpmnResource",
        "trigger",
        "authorizationPolicyKey"
      ],
      "additionalProperties": false,
      "properties": {
        "stableKey": {
          "$ref": "#/$defs/stableKey"
        },
        "processDefinitionKey": {
          "$ref": "#/$defs/stableKey"
        },
        "businessVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "bpmnResource": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_./-]+\\.bpmn20\\.xml$",
          "maxLength": 300
        },
        "trigger": {
          "enum": [
            "MANUAL",
            "OBJECT_CREATED",
            "STATE_TRANSITION",
            "DOMAIN_EVENT"
          ]
        },
        "objectTypeKey": {
          "$ref": "#/$defs/stableKey"
        },
        "eventType": {
          "type": "string",
          "pattern": "^pdp\\.[a-z0-9.-]+$",
          "maxLength": 150
        },
        "authorizationPolicyKey": {
          "$ref": "#/$defs/stableKey"
        },
        "variableMappings": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "maxLength": 200
          },
          "default": {}
        },
        "startupConditionRuleKey": {
          "description": "启动条件规则键；启动前必须满足该规则。",
          "oneOf": [
            {
              "$ref": "#/$defs/stableKey"
            },
            {
              "type": "null"
            }
          ]
        },
        "declaredPermissions": {
          "type": "array",
          "description": "声明本绑定所需权限；不允许提升当前用户权限。",
          "uniqueItems": true,
          "items": {
            "type": "string"
          },
          "default": []
        },
        "instanceMigrationPolicy": {
          "enum": [
            "PINNED",
            "MANUAL_REVIEW",
            "BATCH_MIGRATABLE"
          ],
          "default": "PINNED"
        },
        "migrationValidationRuleKey": {
          "description": "迁移校验规则键；版本化绑定升级前必须通过该校验。",
          "oneOf": [
            {
              "$ref": "#/$defs/stableKey"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "pageDefinition": {
      "type": "object",
      "required": [
        "stableKey",
        "objectKey",
        "layout"
      ],
      "additionalProperties": false,
      "properties": {
        "stableKey": {
          "$ref": "#/$defs/stableKey"
        },
        "objectKey": {
          "$ref": "#/$defs/stableKey"
        },
        "layout": {
          "type": "object",
          "additionalProperties": true
        },
        "visibilityRuleKey": {
          "$ref": "#/$defs/stableKey"
        }
      }
    },
    "viewDefinition": {
      "type": "object",
      "required": [
        "stableKey",
        "objectKey",
        "viewType"
      ],
      "additionalProperties": false,
      "properties": {
        "stableKey": {
          "$ref": "#/$defs/stableKey"
        },
        "objectKey": {
          "$ref": "#/$defs/stableKey"
        },
        "viewType": {
          "enum": [
            "LIST",
            "BOARD",
            "CALENDAR",
            "TIMELINE",
            "DETAIL"
          ]
        },
        "columns": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stableKey"
          }
        },
        "filters": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "ruleDefinition": {
      "type": "object",
      "required": [
        "stableKey",
        "event",
        "actions",
        "executionIdentity"
      ],
      "additionalProperties": false,
      "properties": {
        "stableKey": {
          "$ref": "#/$defs/stableKey"
        },
        "event": {
          "type": "string",
          "minLength": 1
        },
        "condition": {
          "type": "object",
          "additionalProperties": true
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "enum": [
                  "SET_FIELD",
                  "CREATE_OBJECT",
                  "TRANSITION",
                  "SUBMIT_APPROVAL",
                  "NOTIFY",
                  "CALL_EXTENSION",
                  "EMIT_EVENT"
                ]
              },
              "parameters": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "additionalProperties": false
          }
        },
        "executionIdentity": {
          "enum": [
            "CURRENT_USER",
            "PACKAGE_SERVICE_ACCOUNT"
          ]
        },
        "mode": {
          "enum": [
            "SYNCHRONOUS",
            "ASYNCHRONOUS"
          ],
          "default": "ASYNCHRONOUS"
        },
        "cycleDetectionKey": {
          "description": "循环规则检测分组键；SC-013 发布前必须识别循环规则。",
          "type": "string",
          "maxLength": 100
        }
      }
    },
    "permissionDefinition": {
      "type": "object",
      "required": [
        "capabilityKey",
        "objectKey",
        "operations"
      ],
      "additionalProperties": false,
      "properties": {
        "capabilityKey": {
          "$ref": "#/$defs/stableKey"
        },
        "objectKey": {
          "$ref": "#/$defs/stableKey"
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "fieldKeys": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/stableKey"
          }
        },
        "dataScope": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "extensionDefinition": {
      "type": "object",
      "required": [
        "stableKey",
        "artifact",
        "entrypoint",
        "permissions",
        "timeoutMs"
      ],
      "additionalProperties": false,
      "properties": {
        "stableKey": {
          "$ref": "#/$defs/stableKey"
        },
        "artifact": {
          "type": "string",
          "minLength": 1
        },
        "entrypoint": {
          "type": "string",
          "minLength": 1
        },
        "permissions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 30000
        },
        "memoryMb": {
          "type": "integer",
          "minimum": 16,
          "maximum": 1024
        },
        "signature": {
          "type": "string"
        },
        "isolationPolicy": {
          "enum": [
            "STRICT_SANDBOX",
            "SERVICE_ACCOUNT",
            "EVENT_BRIDGE"
          ],
          "default": "STRICT_SANDBOX"
        },
        "failurePolicy": {
          "enum": [
            "FAIL_FAST",
            "DEGRADE_GRACEFULLY",
            "QUARANTINE"
          ],
          "default": "FAIL_FAST"
        }
      }
    },
    "overrideDefinition": {
      "type": "object",
      "required": [
        "targetStableKey",
        "propertyPath",
        "newValue",
        "reason"
      ],
      "additionalProperties": false,
      "properties": {
        "targetStableKey": {
          "$ref": "#/$defs/stableKey"
        },
        "propertyPath": {
          "type": "string",
          "pattern": "^/",
          "description": "覆盖路径；必须在父包声明的允许覆盖白名单内，否则发布校验失败。"
        },
        "oldValue": {},
        "newValue": {},
        "reason": {
          "type": "string",
          "minLength": 2,
          "maxLength": 1000
        },
        "approvedBy": {
          "description": "覆盖批准人；客户包覆盖行业包必须经批准。",
          "oneOf": [
            {
              "$ref": "#/$defs/principalRef"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "migrationDefinition": {
      "type": "object",
      "required": [
        "fromVersion",
        "toVersion",
        "steps",
        "rollback"
      ],
      "additionalProperties": false,
      "properties": {
        "fromVersion": {
          "type": "string"
        },
        "toVersion": {
          "type": "string"
        },
        "batchStrategy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "batchSize",
            "mode"
          ],
          "properties": {
            "batchSize": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10000
            },
            "mode": {
              "enum": [
                "SEQUENTIAL",
                "PARALLEL_WITH_FAILURE_ISOLATION"
              ]
            },
            "pauseBetweenBatchesMs": {
              "type": "integer",
              "minimum": 0,
              "maximum": 600000
            }
          }
        },
        "failureIsolation": {
          "enum": [
            "ABORT_ALL",
            "ISOLATE_FAILED_KEEP_OTHERS",
            "MANUAL_REVIEW"
          ],
          "default": "ISOLATE_FAILED_KEEP_OTHERS"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "type",
              "parameters"
            ],
            "properties": {
              "type": {
                "enum": [
                  "RENAME_FIELD",
                  "MAP_VALUE",
                  "SPLIT_FIELD",
                  "MERGE_FIELD",
                  "SET_DEFAULT",
                  "CUSTOM_EXTENSION"
                ]
              },
              "parameters": {
                "type": "object",
                "additionalProperties": true
              },
              "idempotencyKey": {
                "description": "步骤级幂等键；FR-168 高风险操作必须可重放。",
                "type": "string",
                "minLength": 16,
                "maxLength": 128
              }
            },
            "additionalProperties": false
          }
        },
        "rollback": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "strategy"
          ],
          "properties": {
            "strategy": {
              "enum": [
                "SNAPSHOT_RESTORE",
                "COMPENSATING_ACTION",
                "MANUAL"
              ]
            },
            "maxReversibleWindow": {
              "description": "可回滚时间窗（秒）；超过此窗口只能前向修复。",
              "type": "integer",
              "minimum": 0,
              "maximum": 604800
            }
          }
        }
      }
    },
    "runtimeSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshotId",
        "snapshotVersion",
        "createdAt",
        "contentHash"
      ],
      "properties": {
        "snapshotId": {
          "$ref": "#/$defs/stableKey"
        },
        "snapshotVersion": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "contentHash": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128
        },
        "parentSnapshotId": {
          "oneOf": [
            {
              "$ref": "#/$defs/stableKey"
            },
            {
              "type": "null"
            }
          ]
        },
        "resolvedObjects": {
          "type": "array",
          "description": "三层继承合并后的对象快照；运行实例绑定此快照。",
          "items": {
            "$ref": "#/$defs/objectDefinition"
          }
        }
      }
    }
  }
}
