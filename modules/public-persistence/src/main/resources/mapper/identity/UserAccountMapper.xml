<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pdp.persistence.identity.mapper.UserAccountMapper">

    <!--
        UserAccount record 构造器映射。
        字段顺序必须与 com.pdp.identity.domain.UserAccount canonical constructor 一致：
        id, username, displayName, email, status, createdAt, updatedAt, revision。
        UUID 走 BINARY(16) TypeHandler；Instant 走 datetime(6) TypeHandler；
        UserStatus 走 StringEnumTypeHandler（name() 稳定键）。
    -->
    <resultMap id="userAccountMap" type="com.pdp.identity.domain.UserAccount">
        <constructor>
            <idArg column="id" javaType="java.util.UUID"
                   typeHandler="com.pdp.persistence.typehandler.UuidBinaryTypeHandler"/>
            <arg column="username" javaType="java.lang.String"/>
            <arg column="display_name" javaType="java.lang.String"/>
            <arg column="email" javaType="java.lang.String"/>
            <arg column="status" javaType="com.pdp.identity.domain.UserStatus"
                 typeHandler="com.pdp.persistence.typehandler.StringEnumTypeHandler"/>
            <arg column="created_at" javaType="java.time.Instant"
                 typeHandler="com.pdp.persistence.typehandler.InstantTypeHandler"/>
            <arg column="updated_at" javaType="java.time.Instant"
                 typeHandler="com.pdp.persistence.typehandler.InstantTypeHandler"/>
            <arg column="revision" javaType="int"/>
        </constructor>
    </resultMap>

    <sql id="allColumns">
        id, username, display_name, email, status, created_at, updated_at, revision
    </sql>

    <select id="selectById" resultMap="userAccountMap">
        SELECT <include refid="allColumns"/>
        FROM user_account
        WHERE id = #{id}
    </select>

    <select id="selectByUsername" resultMap="userAccountMap">
        SELECT <include refid="allColumns"/>
        FROM user_account
        WHERE username = #{username}
    </select>

    <select id="selectByEmail" resultMap="userAccountMap">
        SELECT <include refid="allColumns"/>
        FROM user_account
        WHERE email = #{email}
    </select>

    <select id="selectByStatus" resultMap="userAccountMap">
        SELECT <include refid="allColumns"/>
        FROM user_account
        WHERE status = #{status}
        ORDER BY created_at ASC, id ASC
        LIMIT #{limit}
    </select>

    <insert id="insert" parameterType="com.pdp.identity.domain.UserAccount">
        INSERT INTO user_account
            (id, username, display_name, email, status, created_at, updated_at, revision)
        VALUES
            (#{id, typeHandler=com.pdp.persistence.typehandler.UuidBinaryTypeHandler},
             #{username},
             #{displayName},
             #{email},
             #{status, typeHandler=com.pdp.persistence.typehandler.StringEnumTypeHandler},
             #{createdAt, typeHandler=com.pdp.persistence.typehandler.InstantTypeHandler},
             #{updatedAt, typeHandler=com.pdp.persistence.typehandler.InstantTypeHandler},
             #{revision})
    </insert>

    <!--
        乐观锁更新：WHERE revision = #{expectedRevision}，SET revision = revision + 1。
        返回受影响行数：1=成功；0=版本冲突或不存在。
        @see com.pdp.identity.application.IdentityLifecycleService
    -->
    <update id="updateStatus">
        UPDATE user_account
        SET status = #{newStatus, typeHandler=com.pdp.persistence.typehandler.StringEnumTypeHandler},
            updated_at = #{now, typeHandler=com.pdp.persistence.typehandler.InstantTypeHandler},
            revision = revision + 1
        WHERE id = #{id, typeHandler=com.pdp.persistence.typehandler.UuidBinaryTypeHandler}
          AND revision = #{expectedRevision}
    </update>

</mapper>
