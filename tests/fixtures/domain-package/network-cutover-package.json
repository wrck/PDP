{
  "schemaVersion": "1.1",
  "stableKey": "network.cutover",
  "name": "网络设备割接示例包",
  "description": "用于验证领域状态、日志指标追踪、独立审核、影响预览和发布迁移闭环。",
  "layer": "INDUSTRY",
  "version": "1.0.0",
  "extends": {
    "packageKey": "pdp.standard-delivery",
    "versionRange": "^1.0.0"
  },
  "objects": [
    {
      "stableKey": "project.cutover-extension",
      "kind": "CORE_EXTENSION",
      "coreObjectType": "project",
      "label": {
        "zh-CN": "项目割接扩展"
      },
      "fields": [
        {
          "stableKey": "project.cutover-window",
          "label": {
            "zh-CN": "项目割接窗口"
          },
          "dataType": "DATETIME",
          "indexMode": "SORT"
        }
      ],
      "relations": [],
      "states": [
        {
          "stableKey": "planning",
          "label": {
            "zh-CN": "规划中"
          },
          "topLifecycleState": "PLANNING",
          "initial": true
        },
        {
          "stableKey": "executing",
          "label": {
            "zh-CN": "割接执行中"
          },
          "topLifecycleState": "EXECUTING"
        },
        {
          "stableKey": "closed",
          "label": {
            "zh-CN": "割接关闭"
          },
          "topLifecycleState": "CLOSED",
          "terminal": true
        }
      ],
      "transitions": [
        {
          "stableKey": "start-project-cutover",
          "from": "planning",
          "to": "executing",
          "requiredPermission": "cutover.project-manage"
        },
        {
          "stableKey": "close-project-cutover",
          "from": "executing",
          "to": "closed",
          "requiredPermission": "cutover.project-manage"
        }
      ]
    },
    {
      "stableKey": "deliverable.cutover-extension",
      "kind": "CORE_EXTENSION",
      "coreObjectType": "deliverable",
      "label": {
        "zh-CN": "交付件割接扩展"
      },
      "fields": [
        {
          "stableKey": "deliverable.cutover-evidence",
          "label": {
            "zh-CN": "割接验收证据"
          },
          "dataType": "FILE_REF",
          "required": true
        }
      ],
      "relations": [],
      "states": [
        {
          "stableKey": "draft",
          "label": {
            "zh-CN": "待提交"
          },
          "topLifecycleState": "EXECUTING",
          "initial": true
        },
        {
          "stableKey": "accepted",
          "label": {
            "zh-CN": "已验收"
          },
          "topLifecycleState": "ACCEPTING",
          "terminal": true
        }
      ],
      "transitions": [
        {
          "stableKey": "accept-cutover-evidence",
          "from": "draft",
          "to": "accepted",
          "requiredPermission": "cutover.verify"
        }
      ]
    },
    {
      "stableKey": "cutover.plan",
      "kind": "NEW_OBJECT",
      "label": {
        "zh-CN": "割接单"
      },
      "titleFieldKey": "cutover.title",
      "fields": [
        {
          "stableKey": "cutover.title",
          "label": {
            "zh-CN": "割接标题"
          },
          "dataType": "TEXT",
          "required": true,
          "indexMode": "SEARCH"
        },
        {
          "stableKey": "cutover.window",
          "label": {
            "zh-CN": "割接窗口"
          },
          "dataType": "DATETIME",
          "required": true,
          "indexMode": "SORT"
        },
        {
          "stableKey": "cutover.rollback-plan",
          "label": {
            "zh-CN": "回退方案"
          },
          "dataType": "LONG_TEXT",
          "required": true,
          "sensitive": true
        }
      ],
      "relations": [
        {
          "stableKey": "cutover.project",
          "targetObjectKey": "project.cutover-extension",
          "cardinality": "MANY_TO_ONE",
          "required": true,
          "ownership": "REFERENCE"
        },
        {
          "stableKey": "cutover.steps",
          "targetObjectKey": "cutover.step",
          "cardinality": "ONE_TO_MANY",
          "ownership": "AGGREGATE_CHILD"
        },
        {
          "stableKey": "cutover.resources",
          "targetObjectKey": "cutover.resource",
          "cardinality": "ONE_TO_MANY",
          "ownership": "AGGREGATE_CHILD"
        },
        {
          "stableKey": "cutover.acceptance-deliverable",
          "targetObjectKey": "deliverable.cutover-extension",
          "cardinality": "ONE_TO_ONE",
          "ownership": "REFERENCE"
        }
      ],
      "states": [
        {
          "stableKey": "draft",
          "label": {
            "zh-CN": "草稿"
          },
          "topLifecycleState": "PLANNING",
          "initial": true
        },
        {
          "stableKey": "reviewing",
          "label": {
            "zh-CN": "审核中"
          },
          "topLifecycleState": "PLANNING"
        },
        {
          "stableKey": "executing",
          "label": {
            "zh-CN": "执行中"
          },
          "topLifecycleState": "EXECUTING"
        },
        {
          "stableKey": "verified",
          "label": {
            "zh-CN": "验证完成"
          },
          "topLifecycleState": "ACCEPTING",
          "terminal": true
        },
        {
          "stableKey": "rolled-back",
          "label": {
            "zh-CN": "已回退"
          },
          "topLifecycleState": "CANCELLED",
          "terminal": true
        }
      ],
      "transitions": [
        {
          "stableKey": "submit-review",
          "from": "draft",
          "to": "reviewing",
          "requiredPermission": "cutover.submit",
          "workflowBindingKey": "cutover.approval"
        },
        {
          "stableKey": "start-cutover",
          "from": "reviewing",
          "to": "executing",
          "requiredPermission": "cutover.execute",
          "guardRuleKey": "cutover.precheck"
        },
        {
          "stableKey": "complete-verification",
          "from": "executing",
          "to": "verified",
          "requiredPermission": "cutover.verify"
        },
        {
          "stableKey": "execute-rollback",
          "from": "executing",
          "to": "rolled-back",
          "requiredPermission": "cutover.rollback",
          "guardRuleKey": "cutover.rollback-required"
        }
      ]
    },
    {
      "stableKey": "cutover.step",
      "kind": "NEW_OBJECT",
      "label": {
        "zh-CN": "割接步骤"
      },
      "titleFieldKey": "step.instruction",
      "fields": [
        {
          "stableKey": "step.sequence",
          "label": {
            "zh-CN": "步骤序号"
          },
          "dataType": "INTEGER",
          "required": true,
          "indexMode": "SORT"
        },
        {
          "stableKey": "step.instruction",
          "label": {
            "zh-CN": "执行指令"
          },
          "dataType": "LONG_TEXT",
          "required": true
        },
        {
          "stableKey": "step.execution-log",
          "label": {
            "zh-CN": "执行日志"
          },
          "dataType": "LONG_TEXT"
        }
      ],
      "relations": [
        {
          "stableKey": "step.cutover",
          "targetObjectKey": "cutover.plan",
          "cardinality": "MANY_TO_ONE",
          "required": true,
          "ownership": "REFERENCE"
        }
      ],
      "states": [
        {
          "stableKey": "pending",
          "label": {
            "zh-CN": "待执行"
          },
          "topLifecycleState": "PLANNING",
          "initial": true
        },
        {
          "stableKey": "executing",
          "label": {
            "zh-CN": "执行中"
          },
          "topLifecycleState": "EXECUTING"
        },
        {
          "stableKey": "completed",
          "label": {
            "zh-CN": "已完成"
          },
          "topLifecycleState": "ACCEPTING",
          "terminal": true
        },
        {
          "stableKey": "failed",
          "label": {
            "zh-CN": "失败"
          },
          "topLifecycleState": "CANCELLED",
          "terminal": true
        }
      ],
      "transitions": [
        {
          "stableKey": "execute-step",
          "from": "pending",
          "to": "executing",
          "requiredPermission": "cutover.step-execute"
        },
        {
          "stableKey": "complete-step",
          "from": "executing",
          "to": "completed",
          "requiredPermission": "cutover.step-execute"
        },
        {
          "stableKey": "fail-step",
          "from": "executing",
          "to": "failed",
          "requiredPermission": "cutover.step-execute"
        }
      ]
    },
    {
      "stableKey": "cutover.resource",
      "kind": "NEW_OBJECT",
      "label": {
        "zh-CN": "割接资源"
      },
      "titleFieldKey": "resource.name",
      "fields": [
        {
          "stableKey": "resource.name",
          "label": {
            "zh-CN": "资源名称"
          },
          "dataType": "TEXT",
          "required": true,
          "indexMode": "SEARCH"
        },
        {
          "stableKey": "resource.device-ref",
          "label": {
            "zh-CN": "设备引用"
          },
          "dataType": "OBJECT_REF",
          "required": true
        },
        {
          "stableKey": "resource.config-snapshot",
          "label": {
            "zh-CN": "配置快照"
          },
          "dataType": "FILE_REF",
          "required": true,
          "sensitive": true
        }
      ],
      "relations": [
        {
          "stableKey": "resource.cutover",
          "targetObjectKey": "cutover.plan",
          "cardinality": "MANY_TO_ONE",
          "required": true,
          "ownership": "REFERENCE"
        }
      ],
      "states": [
        {
          "stableKey": "reserved",
          "label": {
            "zh-CN": "已预留"
          },
          "topLifecycleState": "PLANNING",
          "initial": true
        },
        {
          "stableKey": "ready",
          "label": {
            "zh-CN": "已就绪"
          },
          "topLifecycleState": "EXECUTING"
        },
        {
          "stableKey": "released",
          "label": {
            "zh-CN": "已释放"
          },
          "topLifecycleState": "CLOSED",
          "terminal": true
        }
      ],
      "transitions": [
        {
          "stableKey": "mark-resource-ready",
          "from": "reserved",
          "to": "ready",
          "requiredPermission": "cutover.resource-manage"
        },
        {
          "stableKey": "release-resource",
          "from": "ready",
          "to": "released",
          "requiredPermission": "cutover.resource-manage"
        }
      ]
    }
  ],
  "pages": [
    {
      "stableKey": "cutover.detail",
      "objectKey": "cutover.plan",
      "layout": {
        "sections": [
          "basic",
          "precheck",
          "execution",
          "verification",
          "rollback"
        ]
      },
      "visibilityRuleKey": "cutover.readable"
    }
  ],
  "views": [
    {
      "stableKey": "cutover.board",
      "objectKey": "cutover.plan",
      "viewType": "BOARD",
      "columns": [
        "cutover.title",
        "cutover.window"
      ]
    }
  ],
  "rules": [
    {
      "stableKey": "cutover.precheck",
      "event": "transition.start-cutover",
      "condition": {
        "allRequiredChecksPassed": true
      },
      "actions": [
        {
          "type": "CALL_EXTENSION",
          "parameters": {
            "extensionKey": "device.precheck"
          }
        },
        {
          "type": "EMIT_EVENT",
          "parameters": {
            "eventType": "pdp.cutover.precheck-completed"
          }
        }
      ],
      "executionIdentity": "CURRENT_USER",
      "mode": "SYNCHRONOUS"
    },
    {
      "stableKey": "cutover.rollback-required",
      "event": "transition.execute-rollback",
      "condition": {
        "rollbackPlanPresent": true
      },
      "actions": [
        {
          "type": "EMIT_EVENT",
          "parameters": {
            "eventType": "pdp.cutover.rollback-started"
          }
        }
      ],
      "executionIdentity": "CURRENT_USER",
      "mode": "SYNCHRONOUS"
    }
  ],
  "workflowBindings": [
    {
      "stableKey": "cutover.approval",
      "processDefinitionKey": "network.cutover.approval",
      "businessVersion": "1.0.0",
      "bpmnResource": "workflow/network-cutover-approval.bpmn20.xml",
      "trigger": "STATE_TRANSITION",
      "objectTypeKey": "cutover.plan",
      "authorizationPolicyKey": "cutover.approve",
      "variableMappings": {
        "businessObjectId": "object.id",
        "workspaceId": "object.workspaceId"
      },
      "instanceMigrationPolicy": "PINNED"
    }
  ],
  "permissions": [
    {
      "capabilityKey": "cutover.read",
      "objectKey": "cutover.plan",
      "operations": [
        "READ"
      ]
    },
    {
      "capabilityKey": "cutover.submit",
      "objectKey": "cutover.plan",
      "operations": [
        "TRANSITION"
      ]
    },
    {
      "capabilityKey": "cutover.execute",
      "objectKey": "cutover.plan",
      "operations": [
        "TRANSITION",
        "EXECUTE"
      ]
    },
    {
      "capabilityKey": "cutover.verify",
      "objectKey": "cutover.plan",
      "operations": [
        "TRANSITION"
      ]
    },
    {
      "capabilityKey": "cutover.rollback",
      "objectKey": "cutover.plan",
      "operations": [
        "TRANSITION",
        "ROLLBACK"
      ],
      "fieldKeys": [
        "cutover.rollback-plan"
      ]
    },
    {
      "capabilityKey": "cutover.project-manage",
      "objectKey": "project.cutover-extension",
      "operations": [
        "TRANSITION",
        "UPDATE"
      ]
    },
    {
      "capabilityKey": "cutover.step-execute",
      "objectKey": "cutover.step",
      "operations": [
        "TRANSITION",
        "EXECUTE"
      ]
    },
    {
      "capabilityKey": "cutover.resource-manage",
      "objectKey": "cutover.resource",
      "operations": [
        "TRANSITION",
        "UPDATE"
      ],
      "fieldKeys": [
        "resource.config-snapshot"
      ]
    }
  ],
  "extensions": [
    {
      "stableKey": "device.precheck",
      "artifact": "sha256:7d22b757ce4318a4d4f41ab22f078b83b285a89cb2ef1b88d5e9958855d4f918",
      "entrypoint": "com.pdp.cutover.PrecheckExtension",
      "permissions": [
        "device.inventory.read"
      ],
      "timeoutMs": 5000,
      "memoryMb": 128,
      "isolation": "PROCESS",
      "signature": "pdp-signed-example"
    }
  ],
  "overrides": [],
  "migrations": [
    {
      "fromVersion": "0.9.0",
      "toVersion": "1.0.0",
      "steps": [
        {
          "type": "SET_DEFAULT",
          "parameters": {
            "field": "cutover.rollback-plan",
            "value": "按原设备配置快照恢复"
          }
        }
      ],
      "rollback": {
        "type": "RESTORE_SNAPSHOT",
        "snapshot": "runtimeSnapshotId"
      }
    }
  ]
}
