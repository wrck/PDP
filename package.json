{
  "name": "pdp",
  "version": "0.1.0",
  "private": true,
  "description": "PDP 企业级项目交付管理平台 - 根 pnpm 工作区",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.15.0"
  },
  "scripts": {
    "dev": "pnpm --filter pdp-web dev",
    "build": "pnpm --filter pdp-web build",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,vue,js,cjs,mjs,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,js,cjs,mjs,json,md,yaml,yml}\"",
    "test:e2e": "pnpm --filter pdp-tests test:e2e",
    "test:contracts": "pnpm --filter pdp-tests test:contracts",
    "test:perf": "pnpm --filter pdp-tests test:perf"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "eslint": "^9.12.0",
    "@eslint/js": "^9.12.0",
    "typescript-eslint": "^8.8.0",
    "eslint-plugin-vue": "^9.28.0"
  }
}
