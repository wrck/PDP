# 本文件仅作示例，禁止填入真实凭据后提交
#
# 用途：PDP 本地开发与集成测试环境变量模板。
#   - 复制为 .env 后填入本地值；.env 不得提交到仓库。
#   - 所有标记为 CHANGE_ME 的变量必须替换为本地随机值，禁止使用示例值进入任何共享环境。
#   - 生产环境不得使用 .env 文件，必须由外部密钥管理服务（KMS/Vault）注入，详见 docs/configuration.md。
#   - 变量分组与 infra/compose/compose.yaml、specs/002-pdp-product/persistence-design.md 动态数据源拓扑对齐。

# ---------------------------------------------------------------------------
# Spring 运行 Profile
# ---------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev

# ---------------------------------------------------------------------------
# 在线业务事实真源（pdpPrimary，MySQL 8.4 LTS）
# ---------------------------------------------------------------------------
PDP_MYSQL_HOST=pdp-mysql
PDP_MYSQL_PORT=3306
PDP_MYSQL_DATABASE=pdp
PDP_MYSQL_USER=pdp
PDP_MYSQL_ROOT_PASSWORD=CHANGE_ME
PDP_MYSQL_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# Flowable 工作流引擎数据源（workflowEngine，独立 schema/账号，MySQL 8.4 LTS）
# ---------------------------------------------------------------------------
PDP_MYSQL_WORKFLOW_HOST=pdp-mysql-workflow
PDP_MYSQL_WORKFLOW_PORT=3307
PDP_MYSQL_WORKFLOW_DATABASE=pdp_workflow
PDP_MYSQL_WORKFLOW_USER=pdp_workflow
PDP_MYSQL_WORKFLOW_PASSWORD=CHANGE_ME
PDP_MYSQL_WORKFLOW_ROOT_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# 历史 MySQL 迁移源库（migrationSource，只读）
# ---------------------------------------------------------------------------
PDP_MYSQL_LEGACY_HOST=pdp-mysql-legacy
PDP_MYSQL_LEGACY_PORT=3308
PDP_MYSQL_LEGACY_DATABASE=legacy_pdp
PDP_MYSQL_LEGACY_USER=legacy_pdp
PDP_MYSQL_LEGACY_PASSWORD=CHANGE_ME
PDP_MYSQL_LEGACY_ROOT_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# Redis（缓存、限流、短期协调；非业务真源）
# ---------------------------------------------------------------------------
PDP_REDIS_HOST=pdp-redis
PDP_REDIS_PORT=6379
# 本地开发默认不启用密码；如需启用，取消注释并设置：
# PDP_REDIS_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# S3 兼容对象存储（附件与交付件文件内容）
# ---------------------------------------------------------------------------
PDP_OBJECT_STORAGE_ENDPOINT=http://pdp-minio:9000
PDP_OBJECT_STORAGE_ACCESS_KEY=CHANGE_ME
PDP_OBJECT_STORAGE_SECRET_KEY=CHANGE_ME
PDP_OBJECT_STORAGE_BUCKET=pdp-attachments

# ---------------------------------------------------------------------------
# OIDC 企业身份集成
# ---------------------------------------------------------------------------
PDP_OIDC_ISSUER_URL=
PDP_OIDC_CLIENT_ID=
PDP_OIDC_CLIENT_SECRET=CHANGE_ME

# ---------------------------------------------------------------------------
# 签名密钥（游标 HMAC 签名、审计摘要链签名）
# 生产环境必须由 KMS/Vault 托管，应用只保存引用，禁止明文进入环境变量或仓库。
# ---------------------------------------------------------------------------
PDP_AUDIT_SIGNING_KEY=CHANGE_ME
PDP_CURSOR_SIGNING_KEY=CHANGE_ME
